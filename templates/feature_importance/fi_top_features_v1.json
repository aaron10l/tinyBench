{
  "template_id": "fi_top_features_v1",
  "category": "Feature Importance Ranking",
  "answer_format": "feature_ranked_list",
  "question": "You want to build a binary classifier to predict {OUTCOME_COL} and maximize AUROC. Which {K} features are most predictive? Return feature names ranked from most to least predictive as a comma-separated list (e.g. col_a, col_b, col_c).",

  "slots": {
    "OUTCOME_COL": {
      "type": "column",
      "source": "dataset.target",
      "kind_any_of": ["binary"]
    },
    "K": {
      "type": "int",
      "default": 5,
      "min": 1,
      "max": 10
    }
  },

  "feature_pool": {
    "exclude_kinds": ["id_no"],
    "exclude_target": true
  },

  "phenomena": [
    {
      "injector": "fi_top_features",
      "param_mapping": {
        "target_col": "{OUTCOME_COL}"
      }
    }
  ],

  "requirements": [
    {
      "type": "min_feature_count",
      "min": 5
    }
  ]
}
