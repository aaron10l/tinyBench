{
  "template_id": "ix_interaction_dominant_v0",
  "category": "Interaction Detection",
  "answer_format": "column_pair",
  "question": "Which pair of features has the strongest interaction effect on {OUTCOME_COL}? Return the two column names as: column_a, column_b",

  "slots": {
    "OUTCOME_COL": {
      "type": "column",
      "source": "dataset.target",
      "kind_any_of": ["regression"],
      "dtype_any_of": ["int", "float"],
      "unique_count_min": 2
    },
    "EFFECT_STRENGTH": {
      "type": "float",
      "default": 1.5
    }
  },

  "feature_pool": {
    "exclude_target": true,
    "exclude_kinds": ["id_no"],
    "exclude_dtypes": ["empty"]
  },

  "phenomena": [
    {
      "injector": "ix_interaction_dominant",
      "param_mapping": {
        "outcome_col": "{OUTCOME_COL}",
        "effect_strength": "{EFFECT_STRENGTH}"
      }
    }
  ],

  "requirements": [
    {
      "type": "min_feature_count",
      "min": 5
    },
    {
      "type": "min_count_by_dtype_any_of",
      "dtypes": ["int", "float"],
      "min": 3
    }
  ]
}
