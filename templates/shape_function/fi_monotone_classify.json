{
  "template_id": "fi_monotone_classify_v0",
  "category": "Shape Function Interpretation",
  "answer_format": "column_name",
  "question": "For each numeric feature, classify its relationship with {OUTCOME_COL} as MONOTONE (consistently increasing or decreasing) or NON-MONOTONE (changes direction at least once). Which feature has the most non-monotone relationship with the outcome? Return only the feature name.",

  "slots": {
    "OUTCOME_COL": {
      "type": "column",
      "source": "dataset.target",
      "kind_any_of": ["regression"],
      "dtype_any_of": ["int", "float"],
      "unique_count_min": 10
    },
    "EFFECT_STRENGTH": {
      "type": "float",
      "default": 3.0
    }
  },

  "feature_pool": {
    "exclude_target": true,
    "exclude_kinds": ["id_no"],
    "exclude_dtypes": ["empty"]
  },

  "phenomena": [
    {
      "injector": "fi_monotone_classify",
      "param_mapping": {
        "outcome_col": "{OUTCOME_COL}",
        "effect_strength": "{EFFECT_STRENGTH}"
      }
    }
  ],

  "requirements": [
    {
      "type": "min_feature_count",
      "min": 3
    },
    {
      "type": "min_count_by_dtype_any_of",
      "dtypes": ["int", "float"],
      "min": 3
    }
  ]
}
